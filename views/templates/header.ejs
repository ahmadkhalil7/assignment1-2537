<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== "undefined" ? title : "Assignment 2" %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">Assignment 2</a>

        <div class="d-flex gap-2">
            <a href="/" class="btn btn-outline-light btn-sm">Home</a>

            <% if (!user) { %>
                <a href="/signup" class="btn btn-outline-light btn-sm">Sign Up</a>
                <a href="/login" class="btn btn-outline-light btn-sm">Log In</a>
            <% } else { %>
                <a href="/members" class="btn btn-outline-light btn-sm">Members</a>
                <a href="/admin" class="btn btn-warning btn-sm">Admin</a>
                <a href="/logout" class="btn btn-danger btn-sm">Log Out</a>
            <% } %>
        </div>
    </div>
</nav>