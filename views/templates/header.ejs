<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light-subtle">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">Assignment 2 Portal</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <div class="ms-auto d-flex flex-column flex-lg-row gap-2 mt-3 mt-lg-0">
                <% if (user) { %>
                    <a class="btn btn-outline-light rounded-pill" href="/">Home</a>
                    <a class="btn btn-outline-warning rounded-pill" href="/members">Members</a>

                    <% if (user.user_type === "admin") { %>
                        <a class="btn btn-warning rounded-pill" href="/admin">Admin</a>
                    <% } %>

                    <a class="btn btn-danger rounded-pill" href="/logout">Logout</a>
                <% } else { %>
                    <a class="btn btn-outline-light rounded-pill" href="/login">Login</a>
                    <a class="btn btn-warning rounded-pill" href="/signup">Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>

<div class="container py-5">