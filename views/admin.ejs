<%- include("templates/header", { title, user }) %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="fw-bold mb-1">Admin Panel</h1>
        <p class="text-muted mb-0">View users and change user roles.</p>
    </div>
    <a href="/" class="btn btn-outline-dark rounded-pill px-4">Back Home</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="list-group list-group-flush">
            <% users.forEach(u => { %>
                <%- include("templates/user", { user: u }) %>
            <% }) %>
        </div>
    </div>
</div>

<%- include("templates/footer") %>