<%- include("templates/header") %>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Hello, <%= user.name %>!</h1>
        <a href="/logout" class="btn btn-danger">Log Out</a>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-4">
            <div class="card shadow-sm">
                <img src="/cat1.jpg" class="card-img-top img-fluid" alt="Cat 1">
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card shadow-sm">
                <img src="/cat2.jpg" class="card-img-top img-fluid" alt="Cat 2">
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card shadow-sm">
                <img src="/cat3.jpg" class="card-img-top img-fluid" alt="Cat 3">
            </div>
        </div>
    </div>
</div>

<%- include("templates/footer") %>