<%- include("templates/header", { title, user }) %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div>
        <h1 class="fw-bold mb-1">Hello, <%= user.name %>!</h1>
        <p class="text-muted mb-0">Welcome to the members area.</p>
    </div>
    <a href="/logout" class="btn btn-danger rounded-pill px-4">Sign Out</a>
</div>

<div class="row g-4">
    <% images.forEach(image => { %>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <img src="/<%= image %>" class="card-img-top rounded-top-4" alt="Members gallery image">
                <div class="card-body">
                    <p class="card-text text-muted mb-0">Gallery image for logged-in members.</p>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<%- include("templates/footer") %>